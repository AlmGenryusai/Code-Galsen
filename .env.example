# =============================================================================
# .env.example — Code Galsen
# Copier vers .env.local (front Next.js) et supabase/.env (backend).
# Ne JAMAIS committer .env.local / supabase/.env (cf .gitignore).
# =============================================================================

# -------------------------------
# FRONT (Next.js)
# -------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Code Galsen"

# Supabase — projet web ouvert dans dashboard
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# clé service uniquement côté Edge Functions, jamais NEXT_PUBLIC
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# JWT pass offline — clé publique RS256 (embarquée dans bundle pour vérif locale)
NEXT_PUBLIC_PASS_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqh...\n-----END PUBLIC KEY-----"

# CDN / Storage
NEXT_PUBLIC_CONTENT_CDN_URL=https://codegalsen.b-cdn.net
NEXT_PUBLIC_DATASET_MANIFEST_URL=https://codegalsen.b-cdn.net/manifest/v1.json

# Analytics + Monitoring
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=codegalsen.com
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@sentry.io/xxxxx

# Captcha
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=

# -------------------------------
# BACKEND (Supabase Edge Functions)
# -------------------------------
# Africa's Talking — OTP SMS
AT_API_KEY=
AT_USERNAME=sandbox
AT_SMS_SENDER=GALSEN

# PayDunya
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_MODE=test                  # test | live
PAYDUNYA_WEBHOOK_SECRET=             # HMAC pour vérif callback

# JWT pass — clé privée RS256 (signature serveur uniquement)
PASS_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
PASS_JWT_ISSUER=codegalsen.com
PASS_JWT_TTL_DAYS=90

# WhatsApp Business
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=                   # token vérif webhook (string aléatoire)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Upstash Redis (rate-limit OTP)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Bunny.net Storage
BUNNY_STORAGE_ZONE=codegalsen
BUNNY_STORAGE_API_KEY=
BUNNY_CDN_HOSTNAME=codegalsen.b-cdn.net

# -------------------------------
# CI / DEPLOIEMENT (GitHub Actions secrets)
# -------------------------------
# Renseignés dans Settings → Secrets and variables → Actions
# VERCEL_TOKEN
# VERCEL_ORG_ID
# VERCEL_PROJECT_ID
# SUPABASE_ACCESS_TOKEN
# SUPABASE_PROJECT_REF
